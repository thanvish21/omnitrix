{
  "name": "omnitrix",
  "version": "0.1.0",
  "description": "Terminal dashboard themed around Ben 10, Cartoon Network & Anime — watches your AI coding agents (Claude Code, Codex, OpenCode).",
  "type": "module",
  "bin": { "omnitrix": "./dist/index.js" },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ben10", "omnitrix", "tui", "cli", "themes", "anime", "cartoon-network", "claude-code"],
  "repository": { "type": "git", "url": "git+https://github.com/thanvish21/omnitrix.git" },
  "homepage": "https://github.com/thanvish21/omnitrix#readme",
  "bugs": { "url": "https://github.com/thanvish21/omnitrix/issues" },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.3.0",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": { "node": ">=18" }
}
